# ============================================================
#  TELEGRAM
# ============================================================

# Токен бота — получить у @BotFather в Telegram
# Команды: /newbot → задать имя → получить токен
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ID вашего Telegram-канала.
# Формат: @your_channel_username  ИЛИ числовой ID (например -1001234567890)
# Числовой ID можно узнать через @userinfobot, добавив бота в канал
TELEGRAM_CHANNEL_ID=@your_channel_username

# ============================================================
#  HH.RU (HeadHunter / hh.by / hh.kz / hh.am / hh.ge)
# ============================================================

# Токен приложения HH.ru.
# ВАРИАНТ 1: Вставь статический токен (получить на https://dev.hh.ru → Приложения → Токены)
HH_API_TOKEN=

# ВАРИАНТ 2: Client ID + Secret для автоматического получения токена
# Регистрация: https://dev.hh.ru → «Зарегистрировать приложение»
HH_CLIENT_ID=
HH_CLIENT_SECRET=

# ============================================================
#  ИСТОЧНИКИ ВАКАНСИЙ (true = включён, false = пропускать)
# ============================================================

SOURCE_HH=true
SOURCE_RABOTABY=true
SOURCE_DEVBY=true

# ============================================================
#  НАСТРОЙКИ ПАРСИНГА
# ============================================================

# Интервал публикации в минутах (по умолчанию 60 мин)
PUBLISH_INTERVAL_MINUTES=60

# Максимум вакансий за один прогон на один источник/страну
MAX_VACANCIES_PER_RUN=5

# Задержка между запросами в мс (чтобы не получить бан)
REQUEST_DELAY_MS=2000

# Сколько дней хранить ID опубликованной вакансии в data/published.json
# По истечении срока вакансия снова сможет быть опубликована (если ещё активна)
# Рекомендуется: 30 дней (вакансии на hh.ru живут ~30–60 дней)
STORE_TTL_DAYS=30

# ============================================================
#  ЛОГИРОВАНИЕ
# ============================================================

# Уровень логов: error | warn | info | debug
LOG_LEVEL=info
