{
  "name": "vacancies-bot",
  "version": "1.0.0",
  "description": "Telegram bot for posting dev vacancies from BY, RU, GE, AM, KZ",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "nodemon --exec ts-node src/index.ts",
    "store:clear": "node -e \"require('fs').writeFileSync('data/published.json', '{}', 'utf8'); console.log('Store cleared.')\"",
    "store:show": "node -e \"const d=require('./data/published.json'); console.log('Records:', Object.keys(d).length);\""
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cheerio": "^1.0.0-rc.12",
    "cron": "^3.1.6",
    "dotenv": "^16.4.5",
    "node-telegram-bot-api": "^0.66.0",
    "puppeteer": "^22.11.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/cron": "^2.4.0",
    "@types/node": "^20.14.2",
    "@types/node-telegram-bot-api": "^0.64.6",
    "nodemon": "^3.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
